rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['id', 'title', 'watchedAt']) &&
             data.id is string &&
             data.title is string &&
             data.watchedAt is string;
    }

    // Public History (Public Test Account)
    match /public_history/{docId} {
      allow read: if true;
      allow create, update: if isValidHistory(request.resource.data) && isValidId(docId);
      allow delete: if true; 
    }

    // Public Likes
    match /public_likes/{docId} {
      allow read: if true;
      allow create, update: if isValidHistory(request.resource.data) && isValidId(docId);
      allow delete: if true;
    }
  }
}
